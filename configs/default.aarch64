# CONFIG_ARCH_SELECTION_X86_64 is not set
CONFIG_ARCH_SELECTION_AARCH64=y
CONFIG_ARCH_SELECTION="aarch64"

#
# Packages
#
CONFIG_PACKAGES=y
CONFIG_PACKAGE_ZLIB=y
CONFIG_PACKAGE_LIBPNG=y
CONFIG_PACKAGE_LIBPCIACCESS=y
CONFIG_PACKAGE_LIBXML2=y
CONFIG_PACKAGE_LIBDRM=y
CONFIG_PACKAGE_LIBTSM=y
CONFIG_PACKAGE_FRECON=y
CONFIG_PACKAGE_BUSYBOX=y
# end of Packages

#
# Kernel
#
CONFIG_KERNEL=y
CONFIG_KERNEL_RAMFS_BUNDLED=y
# end of Kernel
